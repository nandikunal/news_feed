{
  "openapi": "3.1.0",
  "info": { "title": "Kiezlink Extensions", "version": "1.0.0" },
  "paths": {
    "/v1/auth/register": {
      "post": {
        "summary": "Register user",
        "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "email": { "type": "string" }, "password": { "type": "string" } }, "required": ["email","password"] } } } },
        "responses": { "200": { "description": "User created" } }
      }
    },
    "/v1/auth/login": {
      "post": {
        "summary": "Login and obtain JWT",
        "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "email": { "type": "string" }, "password": { "type": "string" } }, "required": ["email","password"] } } } },
        "responses": { "200": { "description": "Returns access_token and token_type" } }
      }
    },
    "/v1/push/register": {
      "post": {
        "summary": "Register device push token (user-only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "token": { "type": "string" }, "platform": { "type": "string" } }, "required": ["token"] } } } },
        "responses": { "200": { "description": "Device token registered" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  }
}
