{
  "openapi": "3.1.0",
  "info": {
    "title": "RSS News API",
    "description": "Swipe-card RSS backend for a TikTok-style news app.\n\nPass `X-API-Key` header on every request.\n\n- **Read key** (`API_KEY`): Today tab, search, story actions, source list\n- **Admin key** (`ADMIN_API_KEY`): Feed management\n- **Internal key** (`INTERNAL_REFRESH_KEY`): Cron-triggered refresh\n",
    "version": "2.0.0"
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Root",
        "description": "Confirms routing is alive.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
